#!/bin/bash
# Shim: delegates to compiled find-browse binary, falls back to project-local discovery.
DIR="$(cd "$(dirname "$0")/.." && pwd)/dist"
if test -x "$DIR/find-browse"; then
  exec "$DIR/find-browse" "$@"
fi
# Fallback: look under the project's .claude/_nsmm/browse/dist
ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -n "$ROOT" ] && test -x "$ROOT/.claude/_nsmm/browse/dist/browse"; then
  echo "$ROOT/.claude/_nsmm/browse/dist/browse"
  exit 0
fi
echo "ERROR: browse binary not found at <project-root>/.claude/_nsmm/browse/dist/browse." >&2
echo "Rebuild: cd .claude/_nsmm && bun run build" >&2
exit 1
