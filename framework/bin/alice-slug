#!/usr/bin/env bash
# alice-slug — output project slug + sanitized branch + git root.
# Usage: eval "$(alice-slug)"  → sets SLUG, BRANCH, ROOT
set -euo pipefail
ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")
RAW_SLUG=$(git -C "$ROOT" remote get-url origin 2>/dev/null | sed 's|.*[:/]\([^/]*/[^/]*\)\.git$|\1|;s|.*[:/]\([^/]*/[^/]*\)$|\1|' | tr '/' '-') || true
RAW_BRANCH=$(git -C "$ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null | tr '/' '-') || true
SLUG=$(printf '%s' "${RAW_SLUG:-}" | tr -cd 'a-zA-Z0-9._-')
BRANCH=$(printf '%s' "${RAW_BRANCH:-}" | tr -cd 'a-zA-Z0-9._-')
SLUG="${SLUG:-$(basename "$ROOT" | tr -cd 'a-zA-Z0-9._-')}"
BRANCH="${BRANCH:-unknown}"
echo "ROOT=$ROOT"
echo "SLUG=$SLUG"
echo "BRANCH=$BRANCH"
